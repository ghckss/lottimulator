{
  "name": "lottimulation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "build": "NEXT_TEST_WASM_DIR=$PWD/node_modules/@next/swc-wasm-nodejs next build --webpack",
    "dev": "NEXT_TEST_WASM_DIR=$PWD/node_modules/@next/swc-wasm-nodejs next dev --webpack",
    "fetch:lotto": "node --experimental-strip-types scripts/fetch-lotto-history.ts",
    "harness": "node scripts/harness/check-conventions.mjs",
    "lint": "eslint .",
    "start": "next start",
    "test": "node --experimental-strip-types scripts/recommendation.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@next/swc-wasm-nodejs": "16.2.6",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "^9.39.1",
    "eslint-config-next": "latest",
    "eslint-plugin-jsx-a11y": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "latest"
  }
}
